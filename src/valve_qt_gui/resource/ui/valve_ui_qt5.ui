  <property name="styleSheet">
   <string notr="true">
QMainWindow, QWidget#centralwidget{
    background-color:#eef5fb;
    font-family:&quot;Noto Sans CJK SC&quot;, &quot;WenQuanYi Micro Hei&quot;, &quot;Microsoft YaHei&quot;, &quot;SimHei&quot;, &quot;Segoe UI&quot;, Arial;
    color:#102a43;
}
QFrame#headerFrame{
    background-color:qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, stop:0 #0b2d57, stop:0.55 #0f5f9f, stop:1 #1e88d1);
    border-radius:14px;
}
QLabel#logoLabel{
    background-color:rgba(255,255,255,38);
    border:1px solid rgba(255,255,255,80);
    border-radius:18px;
    color:white;
    font-size:26px;
    font-weight:700;
}
QLabel#titleLabel{
    color:white;
    font-size:24px;
    font-weight:700;
}
QLabel#subtitleLabel{
    color:#d9ecff;
    font-size:15px;
}
QLabel#systemStatusLabel{
    color:white;
    background-color:rgba(255,255,255,35);
    border:1px solid rgba(255,255,255,75);
    border-radius:12px;
    padding:10px 18px;
    font-size:17px;
    font-weight:700;
}
QFrame.card{
    background-color:#ffffff;
    border:1px solid #d7e6f5;
    border-radius:14px;
}
QFrame#cameraPanel, QFrame#rightPanel{
    background-color:#ffffff;
    border:1px solid #d5e7f8;
    border-radius:16px;
}
QLabel.sectionTitle{
    color:#0c3b6e;
    font-size:17px;
    font-weight:700;
}
QLabel.hintLabel{
    color:#6b7c93;
    font-size:13px;
}
QPushButton{
    border:none;
    border-radius:9px;
    padding:9px 18px;
    font-size:15px;
    font-weight:600;
    color:white;
    background-color:#2f80c7;
}
QPushButton:hover{ background-color:#1f6fb8; }
QPushButton:pressed{ background-color:#155a96; }
QPushButton#stopCameraButton{
    background-color:#52687d;
}
QPushButton#stopCameraButton:hover{ background-color:#44576b; }
QPushButton#connectArmButton{
    background-color:qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, stop:0 #26a8e8, stop:1 #1c55e8);
    min-height:28px;
}
QPushButton#stopArmButton{
    background-color:#d9534f;
    min-height:28px;
}
QPushButton#stopArmButton:hover{ background-color:#c64541; }
QPushButton#rotateValveButton{
    background-color:qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, stop:0 #1fb6ff, stop:1 #6c3cff);
    border-radius:14px;
    min-height:54px;
    font-size:22px;
    font-weight:800;
}
QComboBox{
    background-color:#ffffff;
    border:1px solid #bfd6ee;
    border-radius:8px;
    padding:7px 12px;
    font-size:15px;
    min-height:24px;
}
QLineEdit, QLabel.valueBox, QLabel.commandBox{
    background-color:#f6faff;
    border:1px solid #c9dff3;
    border-radius:8px;
    padding:8px 12px;
    font-size:15px;
}
QLabel.valueBox{
    color:#0f2742;
    font-weight:700;
}
QLabel#cameraViewLabel{
    background-color:#07111d;
    color:#eaf5ff;
    border:2px solid #143b63;
    border-radius:14px;
    font-size:22px;
    font-weight:700;
}
QFrame.statusCard{
    background-color:#fbfdff;
    border:1px solid #d4e6f8;
    border-radius:18px;
}
QLabel.statusIcon{
    background-color:#eaf4ff;
    border:1px solid #cde5ff;
    border-radius:20px;
    color:#1f74d1;
    font-size:22px;
    font-weight:700;
}
QLabel.statusMain{
    color:#073b72;
    font-size:18px;
    font-weight:800;
}
QLabel.statusSub{
    color:#708399;
    font-size:12px;
}
QTextEdit#commandLogEdit{
    background-color:#f7fbff;
    border:1px solid #cfe2f5;
    border-radius:10px;
    color:#5d7188;
    font-size:14px;
    padding:8px;
}
QLabel.fieldLabel{
    color:#15395f;
    font-size:15px;
    font-weight:650;
}
